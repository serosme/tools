{
  "name": "tools",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.ts",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "nuxt:dev": "nuxt dev --port 3000",
    "nuxt:generate": "nuxt generate",
    "electron:dev": "electron .",
    "dev": "concurrently -k -n nuxt,electron -c cyan,magenta \"npm:nuxt:dev\" \"npm:electron:dev\"",
    "build": "nuxt generate && electron-builder --win"
  },
  "dependencies": {
    "@nuxt/ui": "^4.5.0",
    "nuxt": "^4.3.1",
    "tailwindcss": "^4.2.1",
    "vue": "^3.5.28",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.6.1",
    "concurrently": "^9.2.1",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3"
  },
  "build": {
    "appId": "tools",
    "productName": "Tools",
    "npmRebuild": false,
    "win": {
      "target": "portable"
    },
    "portable": {
      "artifactName": "${productName}-${version}.${ext}"
    }
  }
}
